[
    {
        "name": "topbar",
        "layer": "top",
        "position": "top",
        "height": 30,
        "margin-top": 10,
        "margin-left": 10,
        "margin-right": 10,
        "modules-left": ["sway/mode", "sway/workspaces", "custom/menu", "custom/terminal", "custom/file-manager", "custom/zenbrowser"],
        "modules-center": ["custom/close", "custom/minimize", "custom/maximize", "wlr/taskbar"],
        "modules-right": ["custom/notification", "tray", "battery", "disk", "memory", "cpu", "temperature", "pulseaudio", "custom/headset", "backlight", "idle_inhibitor","network#vpn", "network#wifi", "network#ethernet", "network#disconnected", "custom/mail", "custom/weather", "clock", "custom/poweroff"],
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "яБо",
                "deactivated": "яБ░"
            }
        },
        "sway/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "1": "яВм",
                "2": "яВЖ",
                "3": "яДЫ",
                "4": "яДб",
                "5": "яДа",
                "6": "яЕЫ",
                "7": "яАИ",
                "8": "яВм"
            },
            "persistent-workspaces": {
                "1": ["{output_1}"],
                "2": ["{output_1}"],
                "3": ["{output_1}"],
                "4": ["{output_1}"],
                "5": ["{output_1}"],
                "6": ["{output_1}"],
                "7": ["{output_2}"],
                "8": ["{output_2}"]
            }
        },
        "clock": {
            "interval": 1,
            "format": "<b>{:%Y-%m-%d %H:%M:%S}</b>",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "calendar": {
                "mode"          : "month",
                "mode-mon-col"  : 3,
                "weeks-pos"     : "right",
                "on-scroll"     : 1,
                "on-click-right": "mode",
                "format": {
                          "months":     "<span color='#ffead3'><b>{}</b></span>",
                          "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                          "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                          "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                          "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                          }
                },
            "actions":  {
                "on-click-right": "mode",
                "on-click-forward": "tz_up",
                "on-click-backward": "tz_down",
                "on-scroll-up": "shift_up",
                "on-scroll-down": "shift_down"
                }
        },
        "cpu": {
            "format": "яЛЫ {usage}%",
            "tooltip": false
        },
        "disk": {
            "format": "яВа {}%",
            "tooltip-format": "{used} / {total} used"
        },
        "memory": {
            "format": "яГЙ {}%",
            "tooltip-format": "{used:0.1f}G / {total:0.1f}G used"
        },
        "temperature": {
            "critical-threshold": 80,
            "format": "{icon} {temperatureC}┬░C",
            "format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛЗ"]
        },
        "backlight": {
            "device": "intel_backlight",
            "interval": 1,
            "on-scroll-down": "brightlight -pd 1",
            "on-scroll-up": "brightlight -pi 1",
            "format": "{icon} {percent}%",
            "format-icons": ["яДС", "яЖЕ"],
            "on-click": "wdisplays"
        },
        "battery": {
            "bat": "BAT0",
            "adapter": "AC",
            "interval": 10,
            "full-at": 99,
            "states": {
                "full": 100,
                "good": 99,
                "empty": 5
            },
            "format": "{icon} {capacity}%",
            "format-charging": "яЗж {capacity}%",
            "format-plugged": "яЗж {capacity}%",
            "format-empty": "",
            "format-full": "",
            "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
        },
        "network#disconnected": {
            "tooltip-format": "No connection!",
            "format-ethernet": "",
            "format-wifi": "",
            "format-linked": "яБЧ",
            "format-disconnected": "яБЧ",
            "on-click": "nm-connection-editor"
        },
        "network#ethernet": {
            "interface": "enp*",
            "format-ethernet": "яЮЦ",
            "format-wifi": "",
            "format-linked": "",
            "format-disconnected": "",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
            "on-click": "nm-connection-editor"
        },
        "network#wifi": {
            "interface": "wlp*",
            "format-ethernet": "",
            "format-wifi": "яЗл {essid} ({signalStrength}%)",
            "format-linked": "",
            "format-disconnected": "",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
            "on-click": "nm-connection-editor"
        },
        "network#vpn": {
            "interface": "tun0",
            "format": "яАг",
            "format-disconnected": "",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
            "on-click": "nm-connection-editor"
        },
        "pulseaudio": {
            "scroll-step": 1,
            "format": "{icon} {volume}%{format_source}",
            "format-bluetooth": "{icon}яКФ {volume}%{format_source}",
            "format-bluetooth-muted": "яАж {icon}яКФ{format_source}",
            "format-muted": "яЪй {format_source}",
            "format-source": " яД░ {volume}%",
            "format-source-muted": " яД▒",
            "format-icons": {
                "headphone": "яАе",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАж", "яАз", "яАи"]
            },
            "on-click": "pavucontrol"
        },
        "custom/poweroff": {
            "tooltip": false,
            "format": "яАС",
            "on-click": "bash $HOME/.config/waybar/scripts/poweroff.sh"
        },
        "tray": {
            "icon-size": 20,
            "spacing": 10
        },
        "wlr/taskbar": {
            "format": "{icon} {name}",
            "icon-size": 20,
            "tooltip": false,
            "on-click": "activate",
            "on-click-middle": "close",
            "on-click-right": "minimize-raise",
            "rewrite": {
                "(\\s*)Firefox-Web-Browser": "$1Firefox",
                "(\\s*)Foot Server": "$1Terminal",
                "(\\s*)GNU Image Manipulation Program": "$1GIMP",
                "(\\s*)Rider.*": "$1Rider",
                "(\\s*)WebStorm.*": "$1WebStorm",
                "(\\s*)PhpStorm.*": "$1PhpStorm",
                "(\\s*)Fleet.*": "$1Fleet",
                "(\\s*)CLion.*": "$1CLion",
                "(\\s*)IntelliJ IDEA Ultimate.*": "$1IDEA",
                "(\\s*)Android Studio.*": "$1Android Studio",
                "(\\s*)Code - OSS": "$1Code",
                "(\\s*)Steam \\(Runtime\\)": "$1Steam"
            }
        },
        "sway/mode": {
            "format": "<span style=\"italic\">{}</span>"
        },
        "custom/menu": {
            "format": "яД╡",
            "tooltip": false,
            "on-click": "wofi"
        },
        "custom/file-manager": {
            "format": "яБ╝",
            "tooltip": false,
            "on-click": "nemo"
        },
        "custom/firefox": {
            "format": "яЙй",
            "tooltip": false,
            "on-click": "firefox"
        },
        "custom/vivaldi": {
            "format": "яВм",
            "tooltip": false,
            "on-click": "vivaldi"
        },
        "custom/waterfox": {
            "format": "яЙй",
            "tooltip": false,
            "on-click": "waterfox"
        },
        "custom/zenbrowser": {
            "format": "яЖТ",
            "tooltip": false,
            "on-click": "flatpak run app.zen_browser.zen"
        },
        "custom/terminal": {
            "format": "яДа",
            "tooltip": false,
            "on-click": "foot"
        },
        "custom/discord": {
            "format": "яОТ",
            "tooltip": false,
            "on-click": "flatpak run com.discordapp.Discord"
        },
        "custom/steam": {
            "format": "яЖ╢",
            "tooltip": false,
            "on-click": "steam"
        },
        "custom/notification": {
            "tooltip": false,
            "format": "{icon}",
            "format-icons": {
                "notification": "яВв<span foreground='#{theme_color_accent_red}'><sup>яЖТ</sup></span>",
                "none": "яВв",
                "dnd-notification": "яЗ╖<span foreground='#{theme_color_accent_red}'><sup>яЖТ</sup></span>",
                "dnd-none": "яЗ╖",
                "inhibited-notification": "яВв<span foreground='#{theme_color_accent_red}'><sup>яЖТ</sup></span>",
                "inhibited-none": "яВв",
                "dnd-inhibited-notification": "яЗ╖<span foreground='#{theme_color_accent_red}'><sup>яЖТ</sup></span>",
                "dnd-inhibited-none": "яЗ╖"
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true
        },
        "custom/headset": {
            "tooltip": false,
            "on-click": "bash ${HOME}/.config/waybar/scripts/toggle-audio.sh",
            "exec": "bash ${HOME}/.config/waybar/scripts/get-audio.sh",
            "exec-on-event": true,
            "format": "яЦР",
            "interval": 10,
            "return-type": "json"
        },
        "custom/close": {
            "format": "яАН",
            "tooltip": false,
            "on-click": "swaymsg kill"
        }, 
        "custom/minimize": {
            "format": "яЛС",
            "tooltip": false,
            "on-click": "swaymsg move scratchpad"
        }, 
        "custom/maximize": {
            "format": "яЛР",
            "tooltip": false,
            "on-click": "swaymsg floating toggle"
        }
    }
]